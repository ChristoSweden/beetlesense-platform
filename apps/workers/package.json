    "@bull-board/api": "^6.5.0",
    "@bull-board/express": "^6.5.0",
    "@supabase/supabase-js": "^2.99.2",
    "bullmq": "^5.34.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pdf-parse": "^1.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/pdf-parse": "^1.1.4",
    "tsup": "^8.3.6",
