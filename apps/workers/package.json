{
  "name": "@beetlesense/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.cjs",
    "dashboard": "tsx src/dashboard.ts",
