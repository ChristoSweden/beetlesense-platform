# ─── Supabase Backend ───
# Get these from your Supabase project dashboard (Settings > API)
# Required for production and cloud deployments
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Auth Bypass (Development/Demo Only) ───
# Set to 'true' to skip Supabase auth and use demo user
# NEVER enable in production — this bypasses all security
# Useful for: local dev, CI/CD testing, live demos without real auth
VITE_BYPASS_AUTH=false

# ─── Demo Mode Access ───
# Controls whether "Try Demo" buttons and skipAuth() are available.
# In local dev (import.meta.env.DEV), demo is always enabled regardless.
# On Vercel/production, demo is OFF unless this is explicitly set to 'true'.
# Use for: staging deployments, demo sites, trade show builds
VITE_ENABLE_DEMO=true

# ─── Stripe (publishable key — safe for browser) ───
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Web Push / VAPID (Push Notifications) ───
# Generate with: npx web-push generate-vapid-keys
# The PUBLIC key is safe for the browser. The PRIVATE key goes in Supabase secrets only.
VITE_VAPID_PUBLIC_KEY=

# ─── MapLibre Style URL (optional — falls back to built-in dark OSM style) ───
VITE_MAPLIBRE_STYLE=

# ─── Analytics & Error Tracking ───
VITE_SENTRY_DSN=https://your-dsn@sentry.io/0
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Lantmäteriet (Swedish Property Registry) ───
# Required for real parcel boundary lookups from Fastighetsregistret.
# Get a developer account and API key at: https://www.lantmateriet.se/en/geodata/
# Without this key the app falls back to the free WMS endpoint (less accurate).
VITE_LANTMATERIET_API_KEY=

# ─── Sentinel Hub (Satellite Imagery) ───
# Required for live Sentinel-2 NDVI and moisture analysis.
# Register at https://apps.sentinel-hub.com/dashboard and create an OAuth client.
VITE_SENTINEL_HUB_CLIENT_ID=
VITE_SENTINEL_HUB_CLIENT_SECRET=

# ─── EFI ForestWard Observatory (Server-side only — set in Supabase secrets) ───
# These are NOT VITE_ prefixed — they are never exposed to the browser.
# Set them as Supabase Edge Function secrets via the dashboard or:
#   supabase secrets set EFI_API_KEY=<your-key> EFI_API_ENDPOINT=<url>
#
# Obtain credentials from the EFI grant contact: grants@efi.int
# Reference grant: G-01-2026 (EFI ForestWard Observatory)
# EFI_API_KEY=
# EFI_API_ENDPOINT=https://api.forestward.efi.int/v1/contributions
