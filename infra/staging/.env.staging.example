# =============================================================================
# BeetleSense Staging Environment Variables
# Copy to .env.staging and fill in actual values
# =============================================================================

# ---------- Supabase (Staging Project) ----------
STAGING_SUPABASE_URL=https://your-staging-project.supabase.co
STAGING_SUPABASE_ANON_KEY=eyJ...your-staging-anon-key
STAGING_SUPABASE_SERVICE_ROLE_KEY=eyJ...your-staging-service-role-key

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Object Storage (Staging) ----------
STAGING_S3_ENDPOINT=https://your-staging-project.supabase.co/storage/v1/s3
S3_ACCESS_KEY=your-staging-s3-access-key
S3_SECRET_KEY=your-staging-s3-secret-key
S3_BUCKET=beetlesense-staging

# ---------- External APIs ----------
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-client-secret
LANTMATERIET_API_KEY=your-lantmateriet-key
SMHI_API_KEY=your-smhi-key

# ---------- AI / LLM ----------
GOOGLE_API_KEY=AIza...your-staging-google-api-key
ANTHROPIC_API_KEY=sk-ant-...your-staging-anthropic-key
COMPANION_MODEL=claude-sonnet-4-20250514
COMPANION_MAX_TOKENS=2048

# ---------- Logging ----------
LOG_LEVEL=debug
NODE_ENV=staging

# ---------- Monitoring ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=staging-grafana-password

# ---------- Worker Config ----------
BULL_BOARD_PORT=3001
HEALTH_PORT=3002
MAX_CONCURRENT_JOBS=3
