# ============================================================
# BeetleSense Infrastructure Environment Variables
# Copy to ../.env and fill in real values
# ============================================================

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key

# --- S3-compatible storage ---
S3_ENDPOINT=https://your-s3-endpoint.com
S3_BUCKET=beetlesense-uploads
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=eu-north-1

# --- Inference ---
INFERENCE_URL=http://inference:8000
GPU_MEMORY_LIMIT_MB=4096
ONNX_EXECUTION_PROVIDER=CUDAExecutionProvider

# --- External APIs ---
SENTINEL_HUB_CLIENT_ID=your-sentinel-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-client-secret
LANTMATERIET_API_KEY=your-lantmateriet-key
SMHI_API_KEY=your-smhi-key

# --- AI / LLM ---
OPENAI_API_KEY=sk-...your-openai-key
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key

# --- Web Search ---
BRAVE_SEARCH_API_KEY=BSA...your-brave-search-key

# --- Push Notifications ---
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# --- Bull Board ---
BULL_BOARD_PORT=3001

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=production
