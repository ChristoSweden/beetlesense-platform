{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "System Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 86400 },
              { "color": "green", "value": 604800 }
            ]
          },
          "unit": "dtdurations"
        }
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"beetlesense-workers\"}",
          "legendFormat": "Workers"
        }
      ]
    },
    {
      "title": "Active Jobs by Queue",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "beetlesense_queue_active{queue=~\"$queue\"}",
          "legendFormat": "{{ queue }}"
        }
      ]
    },
    {
      "title": "Queue Depth (Waiting)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "pointSize": 5
          }
        }
      },
      "targets": [
        {
          "expr": "beetlesense_queue_waiting{queue=~\"$queue\"}",
          "legendFormat": "{{ queue }}"
        }
      ]
    },
    {
      "title": "Error Rate (5m avg)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(beetlesense_jobs_failed_total[5m])) / (sum(rate(beetlesense_jobs_processed_total[5m])) + 0.001)",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "title": "Processing Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Processing Time p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(beetlesense_job_duration_seconds_bucket{queue=~\"$queue\"}[5m])) by (le, queue))",
          "legendFormat": "p95 {{ queue }}"
        }
      ]
    },
    {
      "title": "Jobs Processed / Failed (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "bars"
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(beetlesense_jobs_processed_total{queue=~\"$queue\"}[5m]))",
          "legendFormat": "Processed"
        },
        {
          "expr": "sum(rate(beetlesense_jobs_failed_total{queue=~\"$queue\"}[5m]))",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 19 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "beetlesense_gpu_utilization_percent{job=\"beetlesense-inference\"}",
          "legendFormat": "GPU %"
        }
      ]
    },
    {
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 19 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"beetlesense-inference\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"beetlesense-inference\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"beetlesense-inference\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Redis Memory / Connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 19 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Memory Used"
        },
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "Connections"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["beetlesense", "production"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(beetlesense_queue_active, queue)",
        "includeAll": true,
        "multi": true,
        "name": "queue",
        "query": "label_values(beetlesense_queue_active, queue)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "Europe/Stockholm",
  "title": "BeetleSense Platform",
  "uid": "beetlesense-main",
  "version": 1
}
