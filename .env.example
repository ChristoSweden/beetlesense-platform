# ─── BeetleSense.ai — Environment Variables ───
# Copy this file to .env and fill in your values.

# ─── Supabase (Frontend — Vite exposes these to the browser) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Supabase (Backend — workers & edge functions) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── MapLibre (optional — leave empty for default OSM tiles) ───
VITE_MAPLIBRE_STYLE=

# ─── Redis / Valkey (BullMQ workers) ───
REDIS_URL=redis://localhost:6379

# ─── S3-compatible storage (survey uploads, reports) ───
S3_ENDPOINT=https://your-s3-endpoint.com
S3_BUCKET=beetlesense
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# ─── ML Inference API ───
INFERENCE_URL=http://localhost:8000

# ─── AI / LLM Keys ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── External Data APIs ───
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
LANTMATERIET_API_KEY=
SMHI_API_KEY=

# ─── Workers (optional) ───
WORKER_API_URL=http://localhost:3002
