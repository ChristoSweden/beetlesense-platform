# ─── BeetleSense.ai — Environment Variables ───
# Copy this file to .env and fill in your values.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  BROWSER-SAFE VARIABLES (prefix: VITE_)                                │
# │  These are bundled into the client JS and visible to anyone.           │
# │  Never put secrets here. Only use for public keys and config.          │
# └─────────────────────────────────────────────────────────────────────────┘

# ─── Supabase (Frontend — Vite exposes these to the browser) ───
# Get from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Auth Bypass (Development/Demo Only) ───
# Set to 'true' to skip Supabase auth and use demo user automatically
# NEVER enable in production — this bypasses all security
# Useful for: local dev, CI/CD testing, live demos without real backend
VITE_BYPASS_AUTH=false

# ─── MapLibre (optional — leave empty for default OSM tiles) ───
VITE_MAPLIBRE_STYLE=

# ─── PostHog Analytics (EU endpoint — consent-gated in app) ───
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Sentry Error Tracking (EU region — consent-gated in app) ───
VITE_SENTRY_DSN=https://your-dsn@sentry.io/0

# ─── Stripe (publishable key — safe for browser) ───
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Sentinel Hub (browser OAuth client ID) ───
VITE_SENTINEL_HUB_CLIENT_ID=

# ─── Lantmäteriet API (browser key) ───
VITE_LANTMATERIET_API_KEY=

# ─── App Version (set by CI/CD) ───
VITE_APP_VERSION=0.1.0

# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SERVER-ONLY VARIABLES (no VITE_ prefix)                               │
# │  These are used by workers, edge functions, and CI only.               │
# │  NEVER prefix these with VITE_ — that would expose them to the browser.│
# └─────────────────────────────────────────────────────────────────────────┘

# ─── Supabase (Backend — workers & edge functions) ───
# ANON_KEY: Same as VITE_SUPABASE_ANON_KEY
# SERVICE_ROLE_KEY: Admin key — KEEP SECRET! Never expose to browser.
# Get from Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── Redis / Valkey (BullMQ workers) ───
REDIS_URL=redis://localhost:6379

# ─── S3-compatible storage (survey uploads, reports) ───
S3_ENDPOINT=https://your-s3-endpoint.com
S3_BUCKET=beetlesense
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# ─── ML Inference API ───
INFERENCE_URL=http://localhost:8000

# ─── AI / LLM Keys (server-side only) ───
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ─── External Data APIs (server-side) ───
SENTINEL_HUB_CLIENT_SECRET=
LANTMATERIET_API_KEY=
SMHI_API_KEY=

# ─── Stripe (secret keys — server-side only!) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── DJI Cloud API (Drone Fleet Management) ───
DJI_APP_KEY=
DJI_APP_SECRET=
DJI_MQTT_BROKER=mqtts://mqtt.dji.com:8883

# ─── Autel Enterprise Cloud API (Drone Fleet Management) ───
AUTEL_APP_KEY=
AUTEL_APP_SECRET=

# ─── Parrot Cloud API (ANAFI FreeFlight Enterprise) ───
PARROT_API_KEY=

# ─── DroneDeploy (Aerial Mapping Integration) ───
DRONEDEPLOY_API_KEY=

# ─── Pix4Dengine (Headless Photogrammetry) ───
PIX4D_API_KEY=

# ─── ArcGIS Online (Esri GIS Export) ───
ARCGIS_CLIENT_ID=
ARCGIS_CLIENT_SECRET=

# ─── Resend (Email) ───
RESEND_API_KEY=re_...

# ─── Auth Bypass (development only — never use in production) ───
BYPASS_AUTH=false

# ─── Workers (optional) ───
WORKER_API_URL=http://localhost:3002

# ─── EFI ForestWard Observatory (set in Supabase Edge Function secrets) ───
# Obtain credentials from: grants@efi.int (grant G-01-2026)
# EFI_API_KEY=
# EFI_API_ENDPOINT=https://api.forestward.efi.int/v1/contributions
